<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         EMERALD & GOLD — BẢNG MÀU TỐI
         (cùng tập khóa với Palette.Light.xaml, khác giá trị màu)
         ============================================================ -->

    <!-- Nền & bề mặt -->
    <SolidColorBrush x:Key="BrushBackground" Color="#0F1A17"/>
    <SolidColorBrush x:Key="BrushCard"       Color="#16241F"/>
    <SolidColorBrush x:Key="BrushCardAlt"    Color="#1E2F29"/>
    <SolidColorBrush x:Key="BrushHeader"     Color="#16241F"/>
    <SolidColorBrush x:Key="BrushBorder"     Color="#24332D"/>

    <!-- Chữ -->
    <SolidColorBrush x:Key="BrushText"       Color="#E6F0EC"/>
    <SolidColorBrush x:Key="BrushTextMuted"  Color="#9DB0AA"/>

    <!-- Màu chính (emerald sáng hơn cho nền tối) -->
    <SolidColorBrush x:Key="BrushPrimary"      Color="#2BB89A"/>
    <SolidColorBrush x:Key="BrushPrimaryHover" Color="#34CDAD"/>
    <SolidColorBrush x:Key="BrushOnPrimary"    Color="#06231C"/>

    <!-- Màu nhấn (gold) -->
    <SolidColorBrush x:Key="BrushAccent"      Color="#E8B84B"/>
    <SolidColorBrush x:Key="BrushAccentHover" Color="#F0C868"/>
    <SolidColorBrush x:Key="BrushOnAccent"    Color="#2A2410"/>

    <!-- Màu trạng thái -->
    <SolidColorBrush x:Key="BrushSuccess" Color="#2FBE7E"/>
    <SolidColorBrush x:Key="BrushDanger"  Color="#E86A6A"/>
    <SolidColorBrush x:Key="BrushWarning" Color="#F0A93E"/>
    <SolidColorBrush x:Key="BrushInfo"    Color="#5AB0DB"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="BrushSidebar"       Color="#0B1512"/>
    <SolidColorBrush x:Key="BrushSidebarText"   Color="#DCE8E3"/>
    <SolidColorBrush x:Key="BrushSidebarMuted"  Color="#7F968F"/>
    <SolidColorBrush x:Key="BrushSidebarHover"  Color="#16241F"/>
    <SolidColorBrush x:Key="BrushSidebarActive" Color="#08110E"/>

    <!-- Gradient banner / vùng nổi bật -->
    <LinearGradientBrush x:Key="BrushBanner" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#155F4F" Offset="0"/>
        <GradientStop Color="#0C2A23" Offset="1"/>
    </LinearGradientBrush>

    <!-- Màu đổ bóng -->
    <Color x:Key="ColorShadow">#000000</Color>

    <!-- Cờ đánh dấu theme hiện tại -->
    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="TenTheme">Dark</sys:String>
</ResourceDictionary>
