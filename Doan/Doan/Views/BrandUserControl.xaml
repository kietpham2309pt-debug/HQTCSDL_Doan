<UserControl x:Class="Doan.Views.BrandUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan" 
             Height="Auto" Width="Auto"
             Background="#f5f5f5">
    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
    </UserControl.Resources>
    <Grid Margin="0,40,0,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock 
            Grid.Row="0"
            Text="CHỌN HÃNG XE"
            FontSize="24"
            FontWeight="Bold"
            Foreground="#2c3e50"
            Margin="30,0,0,40"/>

        <!-- Danh sách hãng xe -->
        <ItemsControl 
            Grid.Row="1"
            ItemsSource="{Binding HangXeList}"
            Margin="30,0,30,0">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Width="200" 
                        Height="200"
                        Margin="20,20,20,20"
                        Background="White"
                        CornerRadius="10"
                        MouseLeftButtonDown="BrandItem_MouseLeftButtonDown"
                        Cursor="Hand"
                        Effect="{StaticResource ShadowEffect}">

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.25"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Logo -->
                            <Image 
                                Source="{Binding Logo}"
                                
                                Width="80" 
                                Height="80"
                                Margin="0,0,0,20"
                                Stretch="UniformToFill"/>

                            <!-- Tên hãng -->
                            <TextBlock 
                                Text="{Binding TenHang}"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="#2c3e50"
                                TextAlignment="Center"
                                Margin="0,0,0,8"/>

                            <!-- Quốc gia -->
                            <TextBlock 
                                Text="{Binding QuocGia}"
                                FontSize="12"
                                Foreground="#95a5a6"
                                TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>

    

</UserControl>
