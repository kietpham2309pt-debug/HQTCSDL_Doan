<UserControl x:Class="Doan.View.UC_DichVu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan.View"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BrushBackground}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="0,0,10,0" Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding TieuDe}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource BrushText}"/>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="txtSearchDichVu" Width="220" Height="35" VerticalContentAlignment="Center"
                             Tag="Tìm tên phụ tùng..." Padding="10,0" Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Tìm kiếm" Width="80" Margin="5,0" Background="{DynamicResource BrushPrimary}" Foreground="White" BorderThickness="0" Command="{Binding LenhTimKiemDichVu}"/>
                        <TextBlock Text="Loại:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{DynamicResource BrushTextMuted}"
                                   Visibility="{Binding ChoLocLoai, Converter={StaticResource BoolToVis}}"/>
                        <ComboBox Width="120" Height="35" ItemsSource="{Binding DanhSachLoaiLoc}" SelectedItem="{Binding LoaiLocDangChon, Mode=TwoWay}" VerticalContentAlignment="Center"
                                  Visibility="{Binding ChoLocLoai, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="➕ THÊM MỚI" Width="100" Height="35" Background="{DynamicResource BrushSuccess}" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Command="{Binding LenhMoThemDichVu}"/>
                        <Button Content="📝 SỬA" Width="80" Height="35" Background="{DynamicResource BrushWarning}" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Command="{Binding LenhMoSuaDichVu}"/>
                        <Button Content="🗑️ XÓA" Width="80" Height="35" Background="{DynamicResource BrushDanger}" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5,0" Command="{Binding LenhXoaDichVu}"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="dgDichVu" AutoGenerateColumns="False" Background="Transparent" IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="0.5" ItemsSource="{Binding DanhSachDichVu}" SelectedItem="{Binding DichVuDangChon, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Width="70" Binding="{Binding MaPT}"/>
                        <DataGridTextColumn Header="Loại" Width="80" Binding="{Binding Loai}"/>
                        <DataGridTextColumn Header="Tên Dịch vụ / Phụ tùng" Width="*" Binding="{Binding Ten}"/>
                        <DataGridTextColumn Header="Tồn kho" Width="80" Binding="{Binding TonKho}"/>
                        <DataGridTextColumn Header="Đơn giá" Width="120" Binding="{Binding Gia, StringFormat={}{0:N0}}"/>
                        <DataGridTemplateColumn Header="Thêm giỏ hàng" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="CHỌN BÁN"
                                            Background="{DynamicResource BrushPrimary}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Padding="5,2"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.LenhChonBan, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ĐƠN HÀNG TẠM TÍNH" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource BrushWarning}"/>

                <Button DockPanel.Dock="Bottom" Content="TỚI MÀN HÌNH THANH TOÁN" Height="55" Background="{DynamicResource BrushWarning}" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Margin="0,15,0,0" Command="{Binding LenhThanhToan}"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Separator Background="{DynamicResource BrushBorder}" Margin="0,5"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="Tổng tiền tạm tính:" FontSize="14" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock Text="{Binding TongTienTamTinh, StringFormat={}{0:N0} VNĐ}" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushDanger}"/>
                    </Grid>
                </StackPanel>

                <ListBox x:Name="lstSelectedTemp" ItemsSource="{Binding GioHangTam}" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Background="{DynamicResource BrushCardAlt}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="5,10">
                                <Grid Width="310">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TenMatHang}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} VNĐ}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                        <Button Content="-"
                                                Width="22"
                                                Height="22"
                                                Background="{DynamicResource BrushBackground}"
                                                BorderBrush="#DDD"
                                                Command="{Binding DataContext.LenhGiamSoLuongTrongGio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding SoLuong}" Margin="8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <Button Content="+"
                                                Width="22"
                                                Height="22"
                                                Background="{DynamicResource BrushBackground}"
                                                BorderBrush="#DDD"
                                                Command="{Binding DataContext.LenhTangSoLuongTrongGio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="❌"
                                            Foreground="{DynamicResource BrushDanger}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Command="{Binding DataContext.LenhXoaKhoiGio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
