<UserControl x:Class="Doan.View.UC_TheoDoiTraGop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             Background="{DynamicResource BrushBackground}">
    <UserControl.DataContext>
        <vm:TheoDoiTraGop_VM/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="THEO DÕI TRẢ GÓP" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,12"/>

        <!-- KPI -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="SỐ PHIẾU ĐANG TRẢ" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding SoPhieuDangTra}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource BrushPrimary}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="TỔNG CÒN PHẢI THU" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding TongConLai, StringFormat={}{0:N0} đ}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource BrushDanger}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="" Style="{StaticResource KpiLabel}"/>
                    <Button Content="↻ Tải lại" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Padding="16,8" Command="{Binding LenhTaiLai}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Ghi nhận thanh toán -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="GHI NHẬN THANH TOÁN (chọn 1 phiếu bên dưới)" Style="{StaticResource SectionTitle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Số tiền đóng (VNĐ)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBox Text="{Binding SoTienGhiNhan, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="6,0" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Ghi chú" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" Padding="6,0" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✔ Ghi nhận kỳ" VerticalAlignment="Bottom" Height="34" Padding="16,0" Margin="0,0,8,0"
                            Style="{StaticResource SuccessButton}" Command="{Binding LenhGhiNhan}"/>
                    <Button Grid.Column="3" Content="Tất toán" VerticalAlignment="Bottom" Height="34" Padding="16,0"
                            Style="{StaticResource WarningButton}" Command="{Binding LenhTatToan}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding DanhSach}" SelectedItem="{Binding PhieuDangChon, Mode=TwoWay}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="Transparent" BorderThickness="0" RowHeight="34" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã TG" Width="70" Binding="{Binding MaTraGop}"/>
                    <DataGridTextColumn Header="Giao dịch" Width="80" Binding="{Binding MaGiaoDich}"/>
                    <DataGridTextColumn Header="Khách hàng" Width="*" Binding="{Binding TenKhach}"/>
                    <DataGridTextColumn Header="SĐT" Width="110" Binding="{Binding SDT}"/>
                    <DataGridTextColumn Header="Tổng" Width="120" Binding="{Binding TongTien, StringFormat={}{0:N0}}"/>
                    <DataGridTextColumn Header="Số kỳ" Width="60" Binding="{Binding SoKy}"/>
                    <DataGridTextColumn Header="Mỗi kỳ" Width="120" Binding="{Binding SoTienMoiKy, StringFormat={}{0:N0}}"/>
                    <DataGridTextColumn Header="Đã trả" Width="120" Binding="{Binding DaTra, StringFormat={}{0:N0}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Còn lại" Width="120" Binding="{Binding ConLai, StringFormat={}{0:N0}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="{DynamicResource BrushDanger}"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Trạng thái" Width="110" Binding="{Binding TrangThai}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
