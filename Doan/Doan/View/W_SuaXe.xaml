<Window x:Class="Doan.View.W_SuaXe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        mc:Ignorable="d"
        Title="Sửa Xe"
        Height="650"
        Width="650"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="SỬA XE" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource BrushText}" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="{DynamicResource BrushCard}" CornerRadius="8" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Loại xe *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding LoaiXeNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Tên dòng xe *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding TenDongXeNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Màu sắc *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding MauSacNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Năm sản xuất *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NamSXNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Giá bán *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding GiaXeNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Số lượng *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SoLuongTonNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Hình ảnh (URL hoặc đường dẫn file)" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HinhAnhTextBox" Grid.Column="0" Text="{Binding HinhAnhNhap, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Chọn file" Click="ChonHinhAnh_Click" Margin="10,0,0,0"
                                Padding="14,6" Style="{StaticResource PrimaryButton}"/>
                    </Grid>

                    <TextBlock Text="Xem trước:" FontSize="12" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,5"/>
                    <Image x:Name="CarImagePreview" Source="{Binding HinhAnhNhap}" Height="120" Width="200"
                           Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,14"/>

                    <TextBlock Text="Mô tả" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding MoTaNhap, UpdateSourceTrigger=PropertyChanged}" Height="64" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Hủy" Style="{StaticResource GhostButton}" Padding="22,10" Margin="0,0,10,0"
                    Command="{Binding LenhHuyFormXe}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="💾 Lưu thay đổi" Style="{StaticResource WarningButton}" Padding="22,10"
                    Command="{Binding LenhLuuXe}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="ErrorMessageTextBlock" Text="" Foreground="{DynamicResource BrushDanger}"
                   FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Window>
