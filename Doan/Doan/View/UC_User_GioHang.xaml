<UserControl x:Class="Doan.View.UC_User_GioHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BrushBackground}">

    <UserControl.DataContext>
        <vm:User_GioHang_VM/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Bên trái: danh sách sản phẩm trong giỏ -->
        <Border Grid.Column="0" Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="0,0,10,0" Padding="15"
                Effect="{StaticResource ShadowEffect}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBlock Text="🛒 GIỎ HÀNG CỦA TÔI" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushText}"/>
                    <Button HorizontalAlignment="Right" Content="🗑 Xóa tất cả"
                            Padding="12,6" Background="{DynamicResource BrushDanger}" Foreground="White"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                            Command="{Binding LenhXoaTatCa}"/>
                </Grid>

                <DataGrid ItemsSource="{Binding GioHang}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="Transparent" GridLinesVisibility="Horizontal"
                          BorderThickness="0.5" RowHeight="45" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Width="80" Binding="{Binding MaMatHang}"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Width="*" Binding="{Binding TenMatHang}"/>
                        <DataGridTextColumn Header="Đơn giá" Width="120"
                                            Binding="{Binding DonGia, StringFormat={}{0:N0}}"/>
                        <DataGridTemplateColumn Header="Số lượng" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="-" Width="24" Height="24"
                                                Background="#ECF0F1" BorderBrush="{DynamicResource BrushBorder}"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.LenhGiamSoLuong, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding SoLuong}" Margin="10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <Button Content="+" Width="24" Height="24"
                                                Background="#ECF0F1" BorderBrush="{DynamicResource BrushBorder}"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.LenhTangSoLuong, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Thành tiền" Width="140"
                                            Binding="{Binding ThanhTien, StringFormat={}{0:N0}}"/>
                        <DataGridTemplateColumn Header="" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌" Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource BrushDanger}" FontSize="14" Cursor="Hand"
                                            Command="{Binding DataContext.LenhXoaKhoiGio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Bên phải: tóm tắt đơn -->
        <Border Grid.Column="1" Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="15"
                Effect="{StaticResource ShadowEffect}">
            <StackPanel>
                <TextBlock Text="THÔNG TIN ĐẶT HÀNG" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource BrushWarning}" Margin="0,0,0,15"/>

                <TextBlock Text="Người nhận:" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                <TextBlock Text="{Binding TenKhachHienThi}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushText}" Margin="0,3,0,10"/>

                <TextBlock Text="SĐT:" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                <TextBlock Text="{Binding SDTKhachHienThi}" FontSize="13"
                           Foreground="{DynamicResource BrushText}" Margin="0,3,0,10"/>

                <TextBlock Text="Địa chỉ giao:" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                <TextBlock Text="{Binding DiaChiKhachHienThi}" FontSize="13" TextWrapping="Wrap"
                           Foreground="{DynamicResource BrushText}" Margin="0,3,0,15"/>

                <Separator Background="#ECF0F1" Margin="0,5,0,15"/>

                <TextBlock Text="Hình thức thanh toán:" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding DanhSachHinhThucThanhToan}"
                          SelectedItem="{Binding HinhThucThanhToanDangChon, Mode=TwoWay}"
                          Height="32" Margin="0,0,0,10"/>

                <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="6" Padding="10" Margin="0,0,0,12"
                        Visibility="{Binding LaTraGop, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="💳 MUA TRẢ GÓP" FontWeight="Bold" Foreground="{DynamicResource BrushAccent}" Margin="0,0,0,6"/>
                        <TextBlock Text="Trả trước (VNĐ):" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBox Text="{Binding TraTruocNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,3,0,8" VerticalContentAlignment="Center" Padding="6,0"/>
                        <TextBlock Text="Số kỳ (tháng):" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBox Text="{Binding SoKyNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,3,0,0" VerticalContentAlignment="Center" Padding="6,0"/>
                    </StackPanel>
                </Border>

                <Separator Background="#ECF0F1" Margin="0,5,0,15"/>

                <Grid Margin="0,5,0,20">
                    <TextBlock Text="TỔNG TIỀN:" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushDanger}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}"
                               FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushDanger}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <Button Content="✅ ĐẶT HÀNG NGAY"
                        Padding="10,15" Background="{DynamicResource BrushSuccess}" Foreground="White"
                        FontSize="15" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding LenhDatHang}">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2"/>
                    </Button.Effect>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
