<Window x:Class="Doan.View.W_QuenMatKhau"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quên mật khẩu" Height="600" Width="460"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBanner}">
    <Border Background="{DynamicResource BrushCard}" Margin="18" CornerRadius="8">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Quên mật khẩu" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource BrushText}"/>
                <TextBlock Text="Đặt lại mật khẩu bằng câu hỏi bảo mật" FontSize="12" Foreground="{DynamicResource BrushTextMuted}" Margin="0,2,0,14"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Tên đăng nhập" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UsernameBox" Grid.Column="0" Padding="8,8" FontSize="13"
                                 BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>
                        <Button x:Name="BtnLayCauHoi" Grid.Column="1" Content="Lấy câu hỏi" Margin="8,0,0,0"
                                Padding="14,8" Style="{StaticResource PrimaryButton}" Click="BtnLayCauHoi_Click"/>
                    </Grid>

                    <TextBlock Text="Câu hỏi bảo mật" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="4" Padding="10,8">
                        <TextBlock x:Name="CauHoiText" Text="(Nhập tên đăng nhập rồi bấm 'Lấy câu hỏi')"
                                   FontSize="13" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Câu trả lời" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <TextBox x:Name="TraLoiBox" Padding="8,8" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <TextBlock Text="Mật khẩu mới" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <PasswordBox x:Name="MatKhauMoiBox" Padding="8,8" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <TextBlock Text="Xác nhận mật khẩu mới" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <PasswordBox x:Name="XacNhanBox" Padding="8,8" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2" x:Name="BtnDatLai" Content="ĐẶT LẠI MẬT KHẨU" Margin="0,18,0,0" Padding="12,12"
                    Style="{StaticResource SuccessButton}" Click="BtnDatLai_Click"/>
        </Grid>
    </Border>
</Window>
