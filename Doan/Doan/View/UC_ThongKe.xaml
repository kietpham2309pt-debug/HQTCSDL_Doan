<UserControl x:Class="Doan.View.UC_ThongKe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan.View"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BrushBackground}">
    <UserControl.DataContext>
        <vm:ThongKe_VM/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Grid Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📅 Năm:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" Margin="0,0,6,0"/>
                    <ComboBox Width="110" Height="32" ItemsSource="{Binding DanhSachNamLoc}" SelectedItem="{Binding NamLoc, Mode=TwoWay}" Margin="0,0,18,0"/>
                    <TextBlock Text="🚗 Hãng xe:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" Margin="0,0,6,0"/>
                    <ComboBox Width="170" Height="32" ItemsSource="{Binding DanhSachHangLoc}" SelectedItem="{Binding HangLoc, Mode=TwoWay}"/>
                </StackPanel>
                <Button Content="🔄 Làm mới"
                        HorizontalAlignment="Right"
                        Padding="14,6"
                        Background="{DynamicResource BrushPrimary}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding LenhTaiLaiThongKe}"/>
            </Grid>
        <UniformGrid Columns="3" Margin="0,0,0,20">
            <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="TỔNG DOANH THU" Foreground="{DynamicResource BrushTextMuted}" FontSize="12"/>
                    <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} VNĐ}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushSuccess}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="5,0,5,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="HÓA ĐƠN MỚI" Foreground="{DynamicResource BrushTextMuted}" FontSize="12"/>
                    <TextBlock Text="{Binding SoHoaDonMoi}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="10,0,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="KHÁCH HÀNG PHỤC VỤ" Foreground="{DynamicResource BrushTextMuted}" FontSize="12"/>
                    <TextBlock Text="{Binding SoKhachHangPhucVu}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushInfo}"/>
                </StackPanel>
            </Border>
        </UniformGrid>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="0,0,0,20" Padding="20" Height="260">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="DOANH THU 6 THÁNG GẦN NHẤT" FontWeight="Bold" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{Binding DuLieuDoanhThu6Thang}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6" VerticalAlignment="Bottom"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                                <Border Background="{DynamicResource BrushPrimary}" Width="40" 
                                    Height="{Binding ChieuCaoCot}" 
                                    CornerRadius="5,5,0,0"
                                    ToolTip="{Binding GiaTriHienThi}"/>
                                <TextBlock Text="{Binding ThangHienThi}" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🛠️" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock Text="DỊCH VỤ BÁN CHẠY" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushText}"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding DanhSachDichVuBanChay}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" Background="Transparent" BorderThickness="0"
                  RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding TenMuc}" Width="*"/>
                            <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuongBan}" Width="80"/>
                            <DataGridTextColumn Header="Doanh thu" Binding="{Binding DoanhThu, StringFormat={}{0:N0}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="15" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🚗️" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock Text="XE BÁN CHẠY NHẤT" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushText}"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding DanhSachXeBanChay}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" Background="Transparent" BorderThickness="0"
                  RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mẫu xe" Binding="{Binding TenMuc}" Width="*"/>
                            <DataGridTextColumn Header="Đã bán" Binding="{Binding SoLuongBan}" Width="80"/>
                            <DataGridTextColumn Header="Doanh số" Binding="{Binding DoanhThu, StringFormat={}{0:N0}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#E67E22"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== THỐNG KÊ CHI TIẾT THEO MỤC ===== -->
        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock Text="THỐNG KÊ CHI TIẾT THEO MỤC" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,12"/>

            <!-- Xe theo hãng -->
            <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="18" Margin="0,0,0,15">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="🚗 THỐNG KÊ XE THEO HÃNG" FontSize="14" FontWeight="Bold" Foreground="#0E7C66"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrushDanger}"
                                   Text="{Binding TongGiaTriTonXe, StringFormat=Tổng giá trị tồn: {0:N0} VNĐ}"/>
                    </Grid>
                    <DataGrid ItemsSource="{Binding ThongKeTheoHang}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0" RowHeight="32" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hãng" Width="*" Binding="{Binding TenHang}"/>
                            <DataGridTextColumn Header="Số mẫu" Width="90" Binding="{Binding SoMauXe}"/>
                            <DataGridTextColumn Header="Tồn kho" Width="90" Binding="{Binding TongTon}"/>
                            <DataGridTextColumn Header="Đang bán" Width="90" Binding="{Binding SoXeDangBan}"/>
                            <DataGridTextColumn Header="Ẩn" Width="70" Binding="{Binding SoXeAn}"/>
                            <DataGridTextColumn Header="Giá trị tồn (VNĐ)" Width="180" Binding="{Binding GiaTriTon, StringFormat={}{0:N0}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#C0392B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Dịch vụ + Phụ tùng -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="18" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="🛠️ THỐNG KÊ DỊCH VỤ" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding ThongKeDichVu}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" RowHeight="30" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Dịch vụ" Width="*" Binding="{Binding Ten}"/>
                                <DataGridTextColumn Header="SL bán" Width="70" Binding="{Binding SoLuongBan}"/>
                                <DataGridTextColumn Header="Doanh thu" Width="130" Binding="{Binding DoanhThu, StringFormat={}{0:N0}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#27AE60"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="18" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🔧 THỐNG KÊ PHỤ TÙNG" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding ThongKePhuTung}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" RowHeight="30" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Phụ tùng" Width="*" Binding="{Binding Ten}"/>
                                <DataGridTextColumn Header="Tồn" Width="60" Binding="{Binding TonKho}"/>
                                <DataGridTextColumn Header="SL bán" Width="70" Binding="{Binding SoLuongBan}"/>
                                <DataGridTextColumn Header="Doanh thu" Width="130" Binding="{Binding DoanhThu, StringFormat={}{0:N0}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#27AE60"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
