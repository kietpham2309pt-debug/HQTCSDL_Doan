<Window x:Class="Doan.View.MainWindow_User"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        xmlns:vm="clr-namespace:Doan.ViewModel"
        mc:Ignorable="d"
        Title="Cửa Hàng Xe Ô Tô - Khách Hàng" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindow_User_VM/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="{DynamicResource BrushHeader}" Effect="{StaticResource ShadowEffect}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="🚗" FontSize="24" Margin="0,0,15,0"/>
                <TextBlock
                    Text="Cửa Hàng Xe Ô Tô - Trang Khách Hàng"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource BrushText}"
                    VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">
                <Button Content="🔒 Đăng nhập nhân viên"
                        Command="{Binding LenhDangNhapNhanVien}"
                        Style="{StaticResource GhostButton}"
                        FontSize="12" Margin="0,0,20,0"/>
                <Rectangle Width="1" Height="30" Fill="{DynamicResource BrushBorder}" Margin="0,0,20,0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="40" Height="40" Margin="0,0,12,0" Fill="{DynamicResource BrushPrimary}"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            Text="{Binding TenKhachHienThi}"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{DynamicResource BrushText}"/>
                        <TextBlock
                            Text="Khách hàng"
                            FontSize="11"
                            Foreground="{DynamicResource BrushTextMuted}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- CONTENT AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Grid Grid.Column="0" Background="{DynamicResource BrushSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="15,20,15,20" Height="40" Background="{DynamicResource BrushSidebarActive}">
                        <Label
                            Content="MENU KHÁCH HÀNG"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{DynamicResource BrushSidebarText}"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical">

                            <Button Style="{StaticResource MenuButtonStyle}"
                                    Command="{Binding LenhDieuHuong}"
                                    CommandParameter="TrangChu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Trang chủ" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MenuButtonStyle}"
                                    Command="{Binding LenhDieuHuong}"
                                    CommandParameter="XemXe">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚗" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Mua xe" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MenuButtonStyle}"
                                    Command="{Binding LenhDieuHuong}"
                                    CommandParameter="DichVu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛠️" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dịch vụ &amp; phụ tùng" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MenuButtonStyle}"
                                    Command="{Binding LenhDieuHuong}"
                                    CommandParameter="GioHang">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛒" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Giỏ hàng" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MenuButtonStyle}"
                                    Command="{Binding LenhDieuHuong}"
                                    CommandParameter="DonHang">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Đơn của tôi" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Separator Background="{DynamicResource BrushBorder}" Margin="15,15,15,15"/>

                            <Button Style="{StaticResource MenuButtonStyle}"
                                    Command="{Binding LenhDangNhapNhanVien}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Đăng nhập nhân viên" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- MAIN CONTENT -->
            <ContentControl
                Grid.Column="1"
                Content="{Binding ManHinhHienTai}"
                TextElement.Foreground="{DynamicResource BrushText}"
                Background="{DynamicResource BrushBackground}"/>
        </Grid>
    </Grid>
</Window>
