<Window x:Class="Doan.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        xmlns:vm="clr-namespace:Doan.ViewModel"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Bán Xe Ô Tô" Height="800" Width="1400">

    <Window.DataContext>
        <vm:MainWindows_VM/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== TOP HEADER ========== -->
        <Grid Grid.Row="0" Background="White" Effect="{DynamicResource ShadowEffect}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tên hệ thống bên trái -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="🚗" FontSize="24" Margin="0,0,15,0"/>
                <TextBlock 
            Text="Hệ Thống Quản Lý Bán Xe Ô Tô"
            FontSize="18"
            FontWeight="Bold"
            Foreground="#2c3e50"
            VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Icon thông báo, avatar, tên đăng nhập bên phải -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">



                <!-- Divider -->
                <Rectangle Width="1" Height="30" Fill="#ecf0f1" Margin="0,0,20,0"/>

                <!-- Avatar và Tên đăng nhập -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse 
                Width="40" 
                Height="40" 
                Margin="0,0,12,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="#bdc3c7"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock 
                    x:Name="UserNameTextBlock"
                    Text="Quản Trị Viên"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="#2c3e50"/>
                        <TextBlock 
                    Text="Admin"
                    FontSize="11"
                    Foreground="#95a5a6"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ========== CONTENT AREA ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR MENU ========== -->
            <Grid Grid.Column="0" Background="#2c3e50">
                <StackPanel Orientation="Vertical">

                    <!-- Search Box -->
                    <Grid Margin="15,20,15,20" Height="40" Background="#34495e" >
                        <Label
                        Content="MENU CHỨC NĂNG"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        VerticalAlignment="Center" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- Menu Items -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical">

                            <!-- Quản lý xe -->
                            <Button 
                        x:Name="BtnQuanLyXe"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="QuanLyXe"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="QuanLyXe">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚗" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Quản lý xe" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Dịch vụ -->
                            <Button 
                        x:Name="BtnDV"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="DichVu"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="DichVu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛠️" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dịch vụ" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Khách hàng -->
                            <Button 
                        x:Name="BtnKhachHang"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="KhachHang"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="KhachHang">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Khách hàng" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Nhân viên -->
                            <Button 
                        x:Name="BtnNhanVien"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="NhanVien"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="NhanVien">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👨‍💼" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Nhân viên" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Thanh toán -->
                            <Button
                        x:Name="BtnThanhToan"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="ThanhToan"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="ThanhToan">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💳" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Thanh toán" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Lịch sử giao dịch -->
                            <Button
                        x:Name="BtnDonHang"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="LichSu"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="LichSu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Lịch sử giao dịch" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Thông báo -->
                            <Button
                        x:Name="BtnThongBao"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="ThongBao"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="ThongBao">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔔" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Thông báo" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Thống kê -->
                            <Button 
                        x:Name="BtnThongKe"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="ThongKe"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="ThongKe">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Thống kê" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Separator -->
                            <Separator Background="#34495e" Margin="15,15,15,15"/>

                            <!-- Cài đặt -->
                            <Button 
                        x:Name="BtnCaiDat"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="CaiDat"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="CaiDat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Cài đặt" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Đăng xuất -->
                            <Button 
                        x:Name="BtnDangXuat"
                        Style="{DynamicResource MenuButtonStyle}"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="DangXuat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Đăng xuất" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Grid>

            <!-- ========== MAIN CONTENT ========== -->
            <ContentControl 
        Grid.Column="1"
        x:Name="MainContentControl"
        Content="{Binding ManHinhHienTai}"
        Background="White"
        Margin="20"/>
        </Grid>
    </Grid>

    <Window.Resources>
        <!-- Shadow Effect -->
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="3" Opacity="0.15"/>

        <!-- Menu Button Style -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#ecf0f1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495e"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
