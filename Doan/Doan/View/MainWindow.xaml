<Window x:Class="Doan.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        xmlns:vm="clr-namespace:Doan.ViewModel"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Bán Xe Ô Tô" Height="800" Width="1400">

    <Window.DataContext>
        <vm:MainWindows_VM/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== TOP HEADER ========== -->
        <Grid Grid.Row="0" Background="{DynamicResource BrushHeader}" Effect="{DynamicResource ShadowEffect}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tên hệ thống bên trái -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="🚗" FontSize="24" Margin="0,0,15,0"/>
                <TextBlock 
            Text="Hệ Thống Quản Lý Bán Xe Ô Tô"
            FontSize="18"
            FontWeight="Bold"
            Foreground="{DynamicResource BrushText}"
            VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Icon thông báo, avatar, tên đăng nhập bên phải -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">



                <!-- Divider -->
                <Rectangle Width="1" Height="30" Fill="{DynamicResource BrushBorder}" Margin="0,0,20,0"/>

                <!-- Avatar và Tên đăng nhập -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse
                Width="40"
                Height="40"
                Margin="0,0,12,0"
                Fill="{DynamicResource BrushPrimary}"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                    x:Name="UserNameTextBlock"
                    Text="Quản Trị Viên"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="{DynamicResource BrushText}"/>
                        <TextBlock
                    x:Name="RoleTextBlock"
                    Text="Admin"
                    FontSize="11"
                    Foreground="{DynamicResource BrushTextMuted}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ========== CONTENT AREA ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR MENU ========== -->
            <Grid Grid.Column="0" Background="{DynamicResource BrushSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Box -->
                    <Grid Grid.Row="0" Margin="15,20,15,20" Height="40" Background="{DynamicResource BrushSidebarActive}" >
                        <Label
                        Content="MENU CHỨC NĂNG"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource BrushSidebarText}"
                        VerticalAlignment="Center" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- Menu Items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="MenuPanel" Orientation="Vertical">

                            <!-- Quản lý xe -->
                            <Button 
                        x:Name="BtnQuanLyXe"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="QuanLyXe"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="QuanLyXe">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚗" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Quản lý xe" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Dịch vụ -->
                            <Button
                        x:Name="BtnDV"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="DichVu"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="DichVu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛠️" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dịch vụ" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Phụ tùng -->
                            <Button
                        x:Name="BtnPhuTung"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="PhuTung"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="PhuTung">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Phụ tùng" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Tất cả xe -->
                            <Button
                        x:Name="BtnTatCaXe"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="TatCaXe"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="TatCaXe">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚙" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Tất cả xe" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Nhập kho -->
                            <Button
                        x:Name="BtnNhapKho"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="NhapKho"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="NhapKho">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Nhập kho" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Lịch sử nhập -->
                            <Button
                        x:Name="BtnLichSuNhap"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="LichSuNhap"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="LichSuNhap">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📜" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Lịch sử nhập" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Khách hàng -->
                            <Button
                        x:Name="BtnKhachHang"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="KhachHang"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="KhachHang">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Khách hàng" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Nhân viên -->
                            <Button 
                        x:Name="BtnNhanVien"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="NhanVien"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="NhanVien">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👨‍💼" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Nhân viên" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Thanh toán -->
                            <Button
                        x:Name="BtnThanhToan"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="ThanhToan"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="ThanhToan">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💳" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Thanh toán" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Trả góp -->
                            <Button
                        x:Name="BtnTraGop"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="TraGop"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="TraGop">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💳" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Trả góp" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Lịch sử giao dịch -->
                            <Button
                        x:Name="BtnDonHang"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="LichSu"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="LichSu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Lịch sử giao dịch" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Thông báo -->
                            <Button
                        x:Name="BtnThongBao"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="ThongBao"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="ThongBao">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔔" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Thông báo" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Thống kê -->
                            <Button 
                        x:Name="BtnThongKe"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="ThongKe"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="ThongKe">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Thống kê" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Separator -->
                            <Separator Background="{DynamicResource BrushBorder}" Margin="15,15,15,15"/>

                            <!-- Cài đặt -->
                            <Button 
                        x:Name="BtnCaiDat"
                        Style="{DynamicResource MenuButtonStyle}"
                        Tag="CaiDat"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="CaiDat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Cài đặt" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Đăng xuất -->
                            <Button 
                        x:Name="BtnDangXuat"
                        Style="{DynamicResource MenuButtonStyle}"
                        Command="{Binding LenhDieuHuong}"
                        CommandParameter="DangXuat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Đăng xuất" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ========== MAIN CONTENT ========== -->
            <ContentControl
        Grid.Column="1"
        x:Name="MainContentControl"
        Content="{Binding ManHinhHienTai}"
        TextElement.Foreground="{DynamicResource BrushText}"
        Background="{DynamicResource BrushBackground}"
        Margin="20"/>
        </Grid>
    </Grid>

</Window>
