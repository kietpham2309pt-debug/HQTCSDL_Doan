<UserControl x:Class="Doan.View.UC_User_DichVu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BrushBackground}">

    <UserControl.DataContext>
        <vm:User_DichVu_VM/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="15" Effect="{StaticResource ShadowEffect}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="DỊCH VỤ &amp; PHỤ TÙNG"
                           FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,15"/>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Width="250" Height="32" VerticalContentAlignment="Center"
                             Padding="8,0" Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="🔍 Tìm kiếm" Margin="8,0,0,0"
                            Padding="14,6" Background="{DynamicResource BrushPrimary}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding LenhTimKiem}"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- DỊCH VỤ -->
                        <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="6" Padding="10,6" Margin="0,0,0,8">
                            <TextBlock Text="🛠️ DỊCH VỤ" FontSize="15" FontWeight="Bold" Foreground="#0E7C66"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding DanhSachDichVu}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" GridLinesVisibility="Horizontal"
                                  BorderThickness="0.5" RowHeight="40" FontSize="13" Margin="0,0,0,20">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã DV" Width="90" Binding="{Binding MaPT}"/>
                                <DataGridTextColumn Header="Tên dịch vụ" Width="*" Binding="{Binding Ten}"/>
                                <DataGridTextColumn Header="Đơn giá (VNĐ)" Width="150" Binding="{Binding Gia, StringFormat={}{0:N0}}"/>
                                <DataGridTemplateColumn Header="Thao tác" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🛒 Thêm giỏ" Padding="10,4" Margin="3"
                                                    Background="{DynamicResource BrushSuccess}" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.LenhThemVaoGio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- PHỤ TÙNG -->
                        <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="6" Padding="10,6" Margin="0,0,0,8">
                            <TextBlock Text="🔧 PHỤ TÙNG" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding DanhSachPhuTung}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  Background="Transparent" GridLinesVisibility="Horizontal"
                                  BorderThickness="0.5" RowHeight="40" FontSize="13">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã PT" Width="90" Binding="{Binding MaPT}"/>
                                <DataGridTextColumn Header="Tên phụ tùng" Width="*" Binding="{Binding Ten}"/>
                                <DataGridTextColumn Header="Tồn kho" Width="90" Binding="{Binding TonKho}"/>
                                <DataGridTextColumn Header="Đơn giá (VNĐ)" Width="150" Binding="{Binding Gia, StringFormat={}{0:N0}}"/>
                                <DataGridTemplateColumn Header="Thao tác" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🛒 Thêm giỏ" Padding="10,4" Margin="3"
                                                    Background="{DynamicResource BrushSuccess}" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.LenhThemVaoGio, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
