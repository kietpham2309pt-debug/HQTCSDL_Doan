<UserControl x:Class="Doan.View.UC_HoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="750"
             d:DesignWidth="1300"
             Background="{DynamicResource BrushBackground}">
    <UserControl.DataContext>
        <vm:HoaDon_VM/>
    </UserControl.DataContext>

    <Border Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="15" Padding="15">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="LỊCH SỬ GIAO DỊCH" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,15"/>

            <!-- Thanh tìm kiếm + thẻ tổng quan -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBox Width="240" Height="32" VerticalContentAlignment="Center" Padding="6,0" Margin="0,0,5,0"
                             Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Tìm kiếm" Width="90" Height="32" Background="{DynamicResource BrushPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0" Command="{Binding LenhTimKiem}"/>
                    <Button Content="Làm mới" Width="90" Height="32" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding LenhLamMoi}"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource BrushCardAlt}" CornerRadius="6" Padding="14,6" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Tổng số giao dịch" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock Text="{Binding TongSoHoaDon}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource BrushCardAlt}" CornerRadius="6" Padding="14,6">
                    <StackPanel>
                        <TextBlock Text="Tổng doanh thu" FontSize="11" Foreground="{DynamicResource BrushDanger}"/>
                        <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} đ}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushDanger}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Thống kê chi tiết theo phương thức thanh toán -->
            <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,15">
                <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="8" Padding="12,8" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="👥 Khách phục vụ" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock Text="{Binding SoKhachHang}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource BrushInfo}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="8" Padding="12,8" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="📈 Giá trị TB/đơn" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock Text="{Binding GiaTriTrungBinh, StringFormat={}{0:N0} đ}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="8" Padding="12,8" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="💵 Tiền mặt" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock Text="{Binding DoanhThuTienMat, StringFormat={}{0:N0}}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushSuccess}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource BrushCardAlt}" CornerRadius="8" Padding="12,8" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🏦 CK / 💳 Trả góp" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrushWarning}">
                            <Run Text="{Binding DoanhThuChuyenKhoan, StringFormat={}{0:N0}}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding DoanhThuTraGop, StringFormat={}{0:N0}}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <DataGrid ItemsSource="{Binding DanhSachGiaoDich}"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0.5"
                      RowHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã GD" Width="80" Binding="{Binding MaGiaoDich}"/>
                    <DataGridTextColumn Header="Ngày lập" Width="110" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy HH:mm}"/>
                    <DataGridTextColumn Header="Nhân viên" Width="140" Binding="{Binding TenNhanVien}"/>
                    <DataGridTextColumn Header="Khách hàng" Width="130" Binding="{Binding TenKhachHang}"/>
                    <DataGridTextColumn Header="SĐT" Width="110" Binding="{Binding SDT}"/>
                    <DataGridTextColumn Header="Số mặt hàng" Width="90" Binding="{Binding SoMatHang}"/>
                    <DataGridTextColumn Header="Tổng tiền" Width="140" Binding="{Binding TongTien, StringFormat={}{0:N0}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="{DynamicResource BrushDanger}"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PT thanh toán" Width="110" Binding="{Binding PhuongThucThanhToan}"/>
                    <DataGridTextColumn Header="Trạng thái" Width="100" Binding="{Binding TrangThai}"/>
                    <DataGridTemplateColumn Header="" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="👁 Chi tiết" ToolTip="Xem các mặt hàng" Background="{DynamicResource BrushInfo}" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,2" Margin="0,0,6,0"
                                            Command="{Binding DataContext.LenhXemChiTiet, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🖨 In" ToolTip="In hóa đơn" Background="{DynamicResource BrushPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="8,2"
                                            Command="{Binding DataContext.LenhInGiaoDich, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
