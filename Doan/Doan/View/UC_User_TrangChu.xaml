<UserControl x:Class="Doan.View.UC_User_TrangChu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F5F5F5">

    <UserControl.DataContext>
        <vm:User_TrangChu_VM/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Banner chào mừng -->
            <Border CornerRadius="10" Margin="0,0,0,20" Padding="30" Effect="{StaticResource ShadowEffect}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3498DB" Offset="0"/>
                        <GradientStop Color="#2C3E50" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LoiChao}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,10"/>
                        <TextBlock Text="Chào mừng đến với cửa hàng xe ô tô của chúng tôi 🚗"
                                   FontSize="14" Foreground="#ECF0F1" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🚗 XEM XE NGAY"
                                    Padding="18,10" Background="#E74C3C" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Margin="0,0,10,0"
                                    Command="{Binding LenhMoMuaXe}"/>
                            <Button Content="🛠️ DỊCH VỤ"
                                    Padding="18,10" Background="#F39C12" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding LenhMoDichVu}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="🚗️"
                               FontSize="100" VerticalAlignment="Center"
                               Foreground="White" Opacity="0.9"/>
                </Grid>
            </Border>

            <!-- Danh sách hãng xe -->
            <TextBlock Text="CÁC HÃNG XE" FontSize="18" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,5,0,15"/>

            <ItemsControl ItemsSource="{Binding DanhSachHangXe}" Margin="0,0,0,25">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="160" Height="160" Margin="0,0,15,15" Cursor="Hand"
                                BorderThickness="0" Background="Transparent"
                                Command="{Binding DataContext.LenhChonHang, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="Bấm để xem các xe của hãng này">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="White" CornerRadius="10" Effect="{StaticResource ShadowEffect}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="{Binding LogoPath}" Width="70" Height="70" Margin="0,0,0,10" Stretch="Uniform"/>
                                <TextBlock Text="{Binding TenHang}" FontSize="14" FontWeight="Bold"
                                           Foreground="#2C3E50" TextAlignment="Center"/>
                                <TextBlock Text="{Binding QuocGia}" FontSize="11"
                                           Foreground="#95A5A6" TextAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Xe nổi bật -->
            <TextBlock Text="XE NỔI BẬT" FontSize="18" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,5,0,15"/>

            <ItemsControl ItemsSource="{Binding DanhSachXeNoiBat}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180" Margin="0,0,15,15" Background="White"
                                CornerRadius="10" Effect="{StaticResource ShadowEffect}">
                            <StackPanel>
                                <Image Source="{Binding HinhAnh}" Height="120" Stretch="Uniform" Margin="10"/>
                                <StackPanel Margin="10,5,10,10">
                                    <TextBlock Text="{Binding TenXe}" FontSize="13" FontWeight="Bold"
                                               Foreground="#2C3E50" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding HangXe.TenHang}" FontSize="11"
                                               Foreground="#7F8C8D" Margin="0,3,0,5"/>
                                    <TextBlock Text="{Binding GiaBan, StringFormat={}{0:N0} VNĐ}"
                                               FontSize="13" FontWeight="Bold" Foreground="#E74C3C"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
