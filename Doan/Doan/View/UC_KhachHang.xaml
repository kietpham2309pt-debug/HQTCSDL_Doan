<UserControl x:Class="Doan.View.UC_KhachHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.DataContext>
        <vm:KhachHang_VM />
    </UserControl.DataContext>

    <Grid Background="#f4f6f8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="15" Padding="15" Background="White" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Họ tên:" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,6,12,6" Padding="8,5"
                         Text="{Binding HoTenNhap, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="Giới tính:" />
                <ComboBox Grid.Row="0" Grid.Column="3" Margin="0,6,12,6" Padding="8,5"
                          ItemsSource="{Binding DanhSachGioiTinh}"
                          SelectedItem="{Binding GioiTinhNhap, Mode=TwoWay}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Số điện thoại:" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,12,6" Padding="8,5"
                         IsReadOnly="{Binding CoKhachHangDuocChon}"
                         ToolTip="Khi đang sửa, SĐT là khóa theo Stored Procedure."
                         Text="{Binding SoDienThoaiNhap, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="Ngày sinh:" />
                <DatePicker Grid.Row="1" Grid.Column="3" Margin="0,6,12,6"
                            SelectedDate="{Binding NgaySinhNhap, Mode=TwoWay}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Email:" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,12,6" Padding="8,5"
                         Text="{Binding EmailNhap, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Margin="5" Padding="14,8" MinWidth="100"
                            Background="#27ae60" Foreground="White" BorderThickness="0"
                            Command="{Binding LenhThemKhachHang}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,6,0" />
                            <TextBlock Text="Thêm" />
                        </StackPanel>
                    </Button>

                    <Button Margin="5" Padding="14,8" MinWidth="100"
                            Background="#f39c12" Foreground="White" BorderThickness="0"
                            IsEnabled="{Binding CoKhachHangDuocChon}"
                            Command="{Binding LenhSuaKhachHang}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,6,0" />
                            <TextBlock Text="Sửa" />
                        </StackPanel>
                    </Button>

                    <Button Margin="5" Padding="14,8" MinWidth="100"
                            Background="#e74c3c" Foreground="White" BorderThickness="0"
                            IsEnabled="{Binding CoKhachHangDuocChon}"
                            Command="{Binding LenhXoaKhachHang}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" Margin="0,0,6,0" />
                            <TextBlock Text="Xóa" />
                        </StackPanel>
                    </Button>

                    <Button Margin="5" Padding="14,8" MinWidth="100"
                            Background="#34495e" Foreground="White" BorderThickness="0"
                            Command="{Binding LenhLamMoi}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,6,0" />
                            <TextBlock Text="Làm mới" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="15,0,15,10" Padding="15" Background="White" CornerRadius="10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Tìm theo số điện thoại:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0" />
                <TextBox Width="320" Margin="0,0,8,0" Padding="8,5"
                         Text="{Binding TuKhoaSoDienThoai, UpdateSourceTrigger=PropertyChanged}" />
                <Button Margin="0,0,8,0" Padding="12,6" MinWidth="90"
                        Background="#3498db" Foreground="White" BorderThickness="0"
                        Command="{Binding LenhTimKiem}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,6,0" />
                        <TextBlock Text="Tìm" />
                    </StackPanel>
                </Button>
                <Button Padding="12,6" MinWidth="130"
                        Background="#c0392b" Foreground="White" BorderThickness="0"
                        Command="{Binding LenhXoaTheoSoDienThoai}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧹" Margin="0,0,6,0" />
                        <TextBlock Text="Xóa theo SĐT" />
                    </StackPanel>
                </Button>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Margin="15,0,15,15" Padding="12" Background="White" CornerRadius="10">
            <DataGrid ItemsSource="{Binding DanhSachKhachHang}"
                      SelectedItem="{Binding KhachHangDangChon, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã KH" Width="220" Binding="{Binding MaKH}" />
                    <DataGridTextColumn Header="Họ tên" Width="*" Binding="{Binding HoTen}" />
                    <DataGridTextColumn Header="Giới tính" Width="90" Binding="{Binding GioiTinh}" />
                    <DataGridTextColumn Header="Số điện thoại" Width="130" Binding="{Binding SoDienThoai}" />
                    <DataGridTextColumn Header="Ngày sinh" Width="120" Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}" />
                    <DataGridTextColumn Header="Email" Width="220" Binding="{Binding Email}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
