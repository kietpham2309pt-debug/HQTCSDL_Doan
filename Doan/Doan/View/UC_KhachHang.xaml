<UserControl x:Class="Doan.View.UC_KhachHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan.View"
             xmlns:vm="clr-namespace:Doan.ViewModel"
             xmlns:helper="clr-namespace:Doan.Helper"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="{DynamicResource BrushBackground}">
    <UserControl.DataContext>
        <vm:KhachHang_VM/>
    </UserControl.DataContext>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BrushCard}" CornerRadius="10" Margin="0,0,10,0" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="DANH SÁCH KHÁCH HÀNG" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,15"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBox x:Name="txtSearch" Width="200" Height="30" VerticalContentAlignment="Center" Margin="0,0,5,0" Tag="Tìm tên, SĐT..."
                             Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                             helper:AutoCompleteBehavior.Suggestions="{Binding GoiYTimKiem}"/>
                    <Button Content="Tìm kiếm" Width="80" Height="30" Background="{DynamicResource BrushPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding LenhTimKiemKhachHang}"/>
                    <Separator Width="30" Background="Transparent"/>
                    <Button Content="+ Thêm mới" Width="100" Height="30" Background="{DynamicResource BrushSuccess}" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Command="{Binding LenhThemKhachHang}"/>
                    <Button Content="Xóa" Width="80" Height="30" Background="{DynamicResource BrushDanger}" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Command="{Binding LenhXoaKhachHang}"/>
                </StackPanel>
                <DataGrid x:Name="dgCustomers" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="{DynamicResource BrushCard}" BorderThickness="0" RowHeight="35" FontSize="13" ItemsSource="{Binding DanhSachKhachHang}" SelectedItem="{Binding KhachHangDangChon, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKH}" Width="80"/>

                        <DataGridTextColumn Header="Họ và Tên" Binding="{Binding HoTen}" Width="150"/>

                        <DataGridTextColumn Header="Xếp hạng" Binding="{Binding XepHang}" Width="110"/>

                        <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SDT}" Width="110"/>

                        <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="120"/>

                        <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}" Width="90"/>

                        <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="70"/>

                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>

                        <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource BrushCard}" CornerRadius="10" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="THÔNG TIN HỒ SƠ" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Mã khách hàng (Tự động):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding MaKHNhap, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Background="{DynamicResource BrushBorder}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Họ và Tên:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding HoTenNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Số điện thoại:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding SDTNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Số CCCD / Mã số thuế:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding CCCDNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Địa chỉ:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding DiaChiNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Email:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EmailNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Ngày sinh:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <DatePicker SelectedDate="{Binding NgaySinhNhap, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Giới tính:" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding DanhSachGioiTinh}" SelectedItem="{Binding GioiTinhNhap, Mode=TwoWay}" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Ảnh cá nhân (gương mặt):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,0,0,3"/>
                        <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="5" Height="140" Background="{DynamicResource BrushCardAlt}">
                            <Image Source="{Binding AnhCaNhanNhap, TargetNullValue={x:Null}}" Stretch="Uniform" Margin="5"/>
                        </Border>
                        <Button Content="Tải ảnh..." Width="100" Height="28" HorizontalAlignment="Left" Margin="0,5,0,0"
                                Background="{DynamicResource BrushPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Command="{Binding LenhChonAnh}"/>
                    </StackPanel>

                    <Button Content="LƯU / CẬP NHẬT HỒ SƠ"
                        Background="{DynamicResource BrushSuccess}" Foreground="White" 
                        Height="35" FontWeight="Bold" BorderThickness="0" Margin="0,10,0,20"
                        Command="{Binding LenhLuuKhachHang}"/>

                    <Button Content="LÀM MỚI FORM" 
                        Background="#95A5A6" Foreground="White" 
                        Height="35" FontWeight="Bold" BorderThickness="0"
                        Command="{Binding LenhLamMoiKhachHang}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
