<Window x:Class="Doan.View.W_ThemSuaDVxaml"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        mc:Ignorable="d"
        Title="Cập Nhật Dịch Vụ / Phụ Tùng" 
        Height="550" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ECF0F1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="THÔNG TIN DỊCH VỤ &amp; PHỤ TÙNG" 
               FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Effect="{StaticResource ShadowEffect}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Mã dịch vụ / Phụ tùng *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtMaPT" Style="{StaticResource InputStyle}" Tag="Nhập mã (VD: DV001, PT001)" Text="{Binding MaPTNhap, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Tên dịch vụ / Phụ tùng *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtTen" Style="{StaticResource InputStyle}" Text="{Binding TenNhap, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Đơn giá (VNĐ) *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtGia" Style="{StaticResource InputStyle}" Text="{Binding GiaNhap, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Số lượng tồn kho (Đối với phụ tùng)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtTonKho" Style="{StaticResource InputStyle}" Text="{Binding TonKhoNhap, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="* Lưu ý: Để trống Tồn kho nếu là dịch vụ sửa chữa." 
                           FontSize="11" FontStyle="Italic" Foreground="Gray"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnCancel" Content="Hủy bỏ" Width="100" Height="35" 
                Background="#95A5A6" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand" Command="{Binding LenhHuyFormDichVu}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button x:Name="btnSave" Content="Lưu thông tin" Width="120" Height="35" 
                Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding LenhLuuDichVu}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
