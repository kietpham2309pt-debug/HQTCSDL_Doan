<Window x:Class="Doan.View.W_SuaHangXe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
            mc:Ignorable="d"
    Title="Sửa hãng xe" Height="600" Width="600"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#f5f5f5">
    <StackPanel Margin="30" Orientation="Vertical">
        <!-- Tiêu đề -->
        <TextBlock 
    Text="SỬA HÃNG XE"
    FontSize="20"
    FontWeight="Bold"
    Foreground="#2c3e50"
    Margin="0,0,0,20"/>

        <!-- Form -->
        <StackPanel Background="White" Margin="0,0,0,20">

            <!-- Tên hãng -->
            <TextBlock Text="Tên hãng xe *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
            <TextBox 
    x:Name="TenHangTextBox"
    Text="{Binding TenHangNhap, UpdateSourceTrigger=PropertyChanged}"
    Padding="10"
    Margin="0,0,0,15"
    BorderThickness="1"
    BorderBrush="#ecf0f1"
    FontSize="12"/>

            <!-- Quốc gia -->
            <TextBlock Text="Quốc gia *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
            <TextBox 
    x:Name="QuocGiaTextBox"
    Text="{Binding QuocGiaNhap, UpdateSourceTrigger=PropertyChanged}"
    Padding="10"
    Margin="0,0,0,15"
    BorderThickness="1"
    BorderBrush="#ecf0f1"
    FontSize="12"/>

            <!-- Logo -->
            <TextBlock Text="Logo (URL hoặc đường dẫn file)" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBox 
        x:Name="LogoTextBox"
        Grid.Column="0"
        Text="{Binding LogoNhap, UpdateSourceTrigger=PropertyChanged}"
        Padding="10"
        BorderThickness="1"
        BorderBrush="#ecf0f1"
        FontSize="12"/>

                <Button 
        Grid.Column="1"
        Content="Chọn file"
        Margin="10,0,0,0"
        Padding="10"
        Background="#3498db"
        Foreground="White"
        BorderThickness="0"
        Cursor="Hand"/>
            </Grid>

            <!-- Xem trước logo -->
            <TextBlock Text="Xem trước logo:" FontSize="12" Foreground="#2c3e50" Margin="0,0,0,5"/>
            <Image 
    x:Name="LogoPreviewImage"
    Source="{Binding LogoNhap}"
    Height="80"
    Width="80"
    Stretch="UniformToFill"
    Margin="0,0,0,15"/>


        </StackPanel>

        <!-- Nút hành động -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button 
    x:Name="CancelButton"
    Content="Hủy"
    Padding="20,10"
    Margin="0,0,10,0"
    Background="#95a5a6"
    Foreground="White"
    BorderThickness="0"
    Cursor="Hand"
    Command="{Binding LenhHuyFormHangXe}"
    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
    FontSize="12"/>

            <Button 
    x:Name="Sua_Button"
    Content="Sửa hãng xe"
    Padding="20,10"
    Background="#f1c40f"
    Foreground="White"
    BorderThickness="0"
    Cursor="Hand"
    Command="{Binding LenhLuuHangXe}"
    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
    FontSize="12"/>
        </StackPanel>

        <!-- Thông báo lỗi -->
        <TextBlock 
x:Name="ErrorMessageTextBlock"
Text=""
Foreground="#e74c3c"
FontSize="11"
Margin="0,15,0,0"
TextWrapping="Wrap"/>
    </StackPanel>
</Window>
