<Window x:Class="Doan.View.W_SuaHangXe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        mc:Ignorable="d"
        Title="Sửa hãng xe" Height="540" Width="600"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="SỬA HÃNG XE" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource BrushText}" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="{DynamicResource BrushCard}" CornerRadius="8" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Tên hãng xe *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TenHangTextBox" Text="{Binding TenHangNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Quốc gia *" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <TextBox x:Name="QuocGiaTextBox" Text="{Binding QuocGiaNhap, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" FontSize="13"
                             BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>

                    <TextBlock Text="Logo (URL hoặc đường dẫn file)" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LogoTextBox" Grid.Column="0" Text="{Binding LogoNhap, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}" Padding="8,6"/>
                        <Button Grid.Column="1" Content="Chọn file" Click="ChonLogo_Click" Margin="10,0,0,0"
                                Padding="14,6" Style="{StaticResource PrimaryButton}"/>
                    </Grid>

                    <TextBlock Text="Xem trước logo:" FontSize="12" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,5"/>
                    <Image x:Name="LogoPreviewImage" Source="{Binding LogoNhap}" Height="80" Width="80"
                           Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Hủy" Style="{StaticResource GhostButton}" Padding="22,10" Margin="0,0,10,0"
                    Command="{Binding LenhHuyFormHangXe}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="💾 Lưu thay đổi" Style="{StaticResource WarningButton}" Padding="22,10"
                    Command="{Binding LenhLuuHangXe}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="ErrorMessageTextBlock" Text="" Foreground="{DynamicResource BrushDanger}"
                   FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Window>
