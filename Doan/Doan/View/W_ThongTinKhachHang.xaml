<Window x:Class="Doan.View.W_ThongTinKhachHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Thông tin khách hàng" Height="640" Width="470"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBanner}">
    <Border Background="{DynamicResource BrushCard}" Margin="16" CornerRadius="8">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Thông tin khách hàng" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource BrushText}"/>
                <TextBlock Text="Vui lòng nhập đầy đủ thông tin để hoàn tất đặt hàng." FontSize="12" Foreground="{DynamicResource BrushTextMuted}" Margin="0,2,0,14" TextWrapping="Wrap"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Họ và tên *" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="HoTenBox" Padding="8,7" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <TextBlock Text="Số điện thoại *" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <TextBox x:Name="SdtBox" Padding="8,7" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <TextBlock Text="CCCD *" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <TextBox x:Name="CccdBox" Padding="8,7" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <TextBlock Text="Email" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <TextBox x:Name="EmailBox" Padding="8,7" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <TextBlock Text="Địa chỉ *" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <TextBox x:Name="DiaChiBox" Padding="8,7" FontSize="13" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ngày sinh" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker x:Name="NgaySinhPicker"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giới tính" FontSize="12" Foreground="{DynamicResource BrushText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox x:Name="GioiTinhBox" SelectedValuePath="Content">
                                <ComboBoxItem Content="Nam" IsSelected="True"/>
                                <ComboBoxItem Content="Nữ"/>
                                <ComboBoxItem Content="Khác"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="HỦY" Width="90" Height="38" Margin="0,0,10,0" Style="{StaticResource GhostButton}" Click="BtnHuy_Click"/>
                <Button Content="XÁC NHẬN" Width="130" Height="38" Style="{StaticResource SuccessButton}" Click="BtnXacNhan_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
