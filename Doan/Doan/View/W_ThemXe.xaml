<Window x:Class="Doan.View.W_ThemXe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
            mc:Ignorable="d"
    Title="Thêm Xe"
    Height="700"
    Width="650"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#f5f5f5">
    <StackPanel Margin="30" Orientation="Vertical">

        <!-- Tiêu đề -->
        <TextBlock 
Text="THÊM XE MỚI"
FontSize="20"
FontWeight="Bold"
Foreground="#2c3e50"
Margin="0,0,0,20"/>

        <!-- Form -->
        <StackPanel Background="White" Margin="0,0,0,20" Height="473">
            <ScrollViewer Height="472" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Dòng xe -->
                    <TextBlock Text="Loại xe *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <ComboBox 
            x:Name="DongXeComboBox"
            IsEditable="True"
            Text="{Binding LoaiXeNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Margin="0,0,0,15"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"/>
                    <!--Tên xe-->
                    <TextBlock Text="Tên dòng xe *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <TextBox 
            x:Name="TenXeTextBox"
            Text="{Binding TenDongXeNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Margin="0,0,0,15"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"
            Tag="Nhập tên xe cụ thể (VD: Wave Alpha 110)"/>
                    <!-- Màu sắc -->
                    <TextBlock Text="Màu sắc *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <TextBox 
            x:Name="MauSacTextBox"
            Text="{Binding MauSacNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Margin="0,0,0,15"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"/>

                    <!-- Năm sản xuất -->
                    <TextBlock Text="Năm sản xuất *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <TextBox 
            x:Name="NamSanXuatTextBox"
            Text="{Binding NamSXNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Margin="0,0,0,15"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"/>

                    <!-- Giá bán -->
                    <TextBlock Text="Giá bán *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <TextBox 
            x:Name="GiaBanTextBox"
            Text="{Binding GiaXeNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Margin="0,0,0,15"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"/>

                    <!-- Số lượng -->
                    <TextBlock Text="Số lượng *" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <TextBox 
            x:Name="SoLuongTextBox"
            Text="{Binding SoLuongTonNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Margin="0,0,0,15"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"/>

                    <!-- Hình ảnh -->
                    <TextBlock Text="Hình ảnh (URL hoặc đường dẫn file)" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBox 
                x:Name="HinhAnhTextBox"
                Grid.Column="0"
                Text="{Binding HinhAnhNhap, UpdateSourceTrigger=PropertyChanged}"
                Padding="10"
                BorderThickness="1"
                BorderBrush="#ecf0f1"
                FontSize="12"/>

                        <Button 
                Grid.Column="1"
                Content="Chọn file"
                Margin="10,0,0,0"
                Padding="10"
                Background="#3498db"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"/>
                    </Grid>

                    <!-- Preview Hình ảnh -->
                    <TextBlock Text="Xem trước:" FontSize="12" Foreground="#2c3e50" Margin="0,0,0,5"/>
                    <Image 
            x:Name="CarImagePreview"
            Source="{Binding HinhAnhNhap}"
            Height="120"
            Width="200"
            Stretch="UniformToFill"
            Margin="0,0,0,15"/>

                    <!-- Mô tả -->
                    <TextBlock Text="Mô tả" FontSize="12" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,8"/>
                    <TextBox 
            x:Name="MoTaTextBox"
            Text="{Binding MoTaNhap, UpdateSourceTrigger=PropertyChanged}"
            Padding="10"
            Height="60"
            TextWrapping="Wrap"
            BorderThickness="1"
            BorderBrush="#ecf0f1"
            FontSize="12"
            VerticalAlignment="Top"/>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <!-- Nút hành động -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button 
    x:Name="CancelButton"
    Content="Hủy"
    Padding="20,10"
    Margin="0,0,10,0"
    Background="#95a5a6"
    Foreground="White"
    BorderThickness="0"
    Cursor="Hand"
        Command="{Binding LenhHuyFormXe}"
        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
    FontSize="12"/>

            <Button 
    x:Name="SaveButton"
    Content="Thêm xe"
    Padding="20,10"
    Background="#27ae60"
    Foreground="White"
    BorderThickness="0"
    Cursor="Hand"
        Command="{Binding LenhLuuXe}"
        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
    FontSize="12"/>
        </StackPanel>

        <!-- Thông báo lỗi -->
        <TextBlock 
x:Name="ErrorMessageTextBlock"
Text=""
Foreground="#e74c3c"
FontSize="11"
Margin="0,15,0,0"
TextWrapping="Wrap"/>
    </StackPanel>
</Window>
