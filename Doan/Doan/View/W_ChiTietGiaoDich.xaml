<Window x:Class="Doan.View.W_ChiTietGiaoDich"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chi tiết giao dịch" Height="560" Width="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding MaGiaoDich, StringFormat=CHI TIẾT GIAO DỊCH {0}}"
                   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,10,6">
                    <TextBlock Text="Ngày lập" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding NgayLap, StringFormat=dd/MM/yyyy HH:mm}" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,6">
                    <TextBlock Text="Nhân viên lập" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding TenNhanVien}" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                </StackPanel>
                <StackPanel Margin="0,0,10,6">
                    <TextBlock Text="Khách hàng" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding TenKhachHang}" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,6">
                    <TextBlock Text="SĐT" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding SDT}" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                </StackPanel>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Phương thức" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding PhuongThucThanhToan}" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Trạng thái" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding TrangThai}" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimary}"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding DanhSachMatHang}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="Transparent" BorderThickness="0" RowHeight="34">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HĐ" Width="90" Binding="{Binding MaHD}"/>
                    <DataGridTextColumn Header="Tên dịch vụ / sản phẩm" Width="*" Binding="{Binding TenDV_SP}"/>
                    <DataGridTextColumn Header="Số lượng" Width="90" Binding="{Binding SoLuong}"/>
                    <DataGridTextColumn Header="Thành tiền" Width="160" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="{DynamicResource BrushDanger}"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="TỔNG TIỀN: " FontWeight="Bold" Foreground="{DynamicResource BrushText}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrushDanger}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🖨 In hóa đơn" Style="{StaticResource PrimaryButton}" Padding="18,10" Margin="0,0,10,0" Click="In_Click"/>
                <Button Content="Đóng" Style="{StaticResource GhostButton}" Padding="18,10" Click="Dong_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
