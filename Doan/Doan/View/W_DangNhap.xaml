<Window x:Class="Doan.View.W_DangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        xmlns:vm="clr-namespace:Doan.ViewModel"
            mc:Ignorable="d"
    Title="Hệ Thống Quản Lý Bán Xe Máy" Height="600" Width="900"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    Foreground="#333333">

    <Window.DataContext>
        <vm:DangNhap_VM/>
    </Window.DataContext>

    <Window.Resources>
        <DropShadowEffect 
     x:Key="ShadowEffect"
     BlurRadius="15"
     ShadowDepth="5"
     Opacity="0.3"/>
    </Window.Resources>
    <Grid Background="#34495e">
        <!-- Container chính -->
        <StackPanel 
    VerticalAlignment="Center" 
    HorizontalAlignment="Center"
    Width="420"
    Background="White"
    Effect="{StaticResource ShadowEffect}">

            <!-- Header -->
            <TextBlock 
        Text="Đăng Nhập Hệ Thống"
        FontSize="28"
        FontWeight="Bold"
        Foreground="#2c3e50"
        TextAlignment="Center"
        Margin="0,30,0,10"/>

            <TextBlock 
        Text="Hệ thống quản lý bán xe oto"
        FontSize="14"
        Foreground="#95a5a6"
        TextAlignment="Center"
        Margin="0,0,0,30"/>

            <!-- Username -->
            <TextBlock 
        Text="Tên đăng nhập"
        FontSize="13"
        Foreground="#2c3e50"
        FontWeight="Medium"
        Margin="30,0,30,8"/>

            <Grid Margin="30,0,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
            Grid.Column="0"
            Text="👤"
            FontSize="18"
            VerticalAlignment="Center"
            Foreground="#95a5a6"/>

                <TextBox 
            x:Name="UsernameTextBox"
            Grid.Column="1"
            Margin="10,0,0,0"
            Padding="10,12"
            FontSize="13"
            Foreground="#2c3e50"
            BorderThickness="0,0,0,1"
            BorderBrush="#ecf0f1"
            Background="Transparent"
            Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Password -->
            <TextBlock 
        Text="Mật khẩu"
        FontSize="13"
        Foreground="#2c3e50"
        FontWeight="Medium"
        Margin="30,0,30,8"/>

            <Grid Margin="30,0,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
            Grid.Column="0"
            Text="🔒"
            FontSize="18"
            VerticalAlignment="Center"
            Foreground="#95a5a6"/>

                <PasswordBox 
            x:Name="PasswordBox"
            Grid.Column="1"
            Margin="10,0,0,0"
            Padding="10,12"
            FontSize="13"
            BorderThickness="0,0,0,1"
            BorderBrush="#ecf0f1"
            Background="Transparent"/>

                <TextBox
            x:Name="PasswordTextBox"
            Grid.Column="1"
            Margin="10,0,0,0"
            Padding="10,12"
            FontSize="13"
            BorderThickness="0,0,0,1"
            BorderBrush="#ecf0f1"
            Background="Transparent"
            Visibility="Collapsed"/>

                <Button 
            x:Name="TogglePasswordButton"
            Grid.Column="2"
            Content="👁"
            Background="Transparent"
            BorderThickness="0"
            Foreground="#95a5a6"
            FontSize="14"
            Click="TogglePasswordButton_Click"
            Cursor="Hand"/>
            </Grid>
            <!-- Loại tài khoản -->
            <TextBlock 
        Text="Loại tài khoản"
        FontSize="13"
        Foreground="#2c3e50"
        FontWeight="Medium"
        Margin="30,0,30,12"/>

            <StackPanel Margin="30,0,30,20" Orientation="Horizontal">
                <RadioButton 
            x:Name="AdminRadioButton"
            Content="Admin"
            IsChecked="False"
            VerticalAlignment="Center"
            Foreground="#7f8c8d"
            FontSize="12"
            Margin="0,0,30,0"/>

                <RadioButton 
            x:Name="StaffRadioButton"
            Content="Khách hàng"
            IsChecked="True"
            VerticalAlignment="Center"
            Foreground="#7f8c8d"
            FontSize="12"/>
            </StackPanel>

            <!-- Nút Đăng nhập -->
            <Button 
        x:Name="LoginButton"
        Content="🔐 ĐĂNG NHẬP"
        Margin="30,0,30,20"
        Padding="15,12"
        FontSize="14"
        FontWeight="Bold"
        Foreground="White"
        Background="#3498db"
        BorderThickness="0"
        Command="{Binding LenhDangNhap}"
        CommandParameter="{Binding ElementName=PasswordBox}" 
        Cursor="Hand"/>

            <TextBlock 
        TextAlignment="Center" 
        Foreground="#7f8c8d" 
        FontSize="11" 
        Margin="0,0,0,20">
        <Run Text="Chưa có tài khoản?"/>
        <Hyperlink Foreground="#3498db"
                   Command="{Binding LenhMoDangKy}"
                   CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
            <Run Text=" Đăng ký ngay"/>
        </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
