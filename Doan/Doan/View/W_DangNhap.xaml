<Window x:Class="Doan.View.W_DangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.View"
        xmlns:vm="clr-namespace:Doan.ViewModel"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Bán Xe Ô Tô" Height="600" Width="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Foreground="#333333">
    <Window.DataContext>
        <vm:DangNhap_VM/>
    </Window.DataContext>

    <Window.Resources>
        <DropShadowEffect 
         x:Key="ShadowEffect"
         BlurRadius="15"
         ShadowDepth="5"
         Opacity="0.3"/>
    </Window.Resources>
    <Grid Background="{DynamicResource BrushBanner}">
        <!-- Container chính -->
        <StackPanel
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Width="420"
        Background="{DynamicResource BrushCard}"
        Effect="{StaticResource ShadowEffect}">

            <!-- Header -->
            <TextBlock 
            Text="Đăng Nhập Hệ Thống"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource BrushText}"
            TextAlignment="Center"
            Margin="0,30,0,10"/>

            <TextBlock
            Text="Dành cho Nhân viên / Quản trị"
            FontSize="14"
            Foreground="{DynamicResource BrushTextMuted}"
            TextAlignment="Center"
            Margin="0,0,0,20"/>

            <!-- Loại tài khoản -->
            <TextBlock Text="Loại tài khoản" FontSize="13" FontWeight="Medium"
                       Foreground="{DynamicResource BrushText}" Margin="30,0,30,8"/>
            <Grid Margin="30,0,30,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="👤 Nhân viên" Height="40" Command="{Binding LenhChonNhanVien}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LaAdmin}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource BrushPrimary}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource BrushOnPrimary}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" Content="🛡️ Quản trị (Admin)" Height="40" Command="{Binding LenhChonAdmin}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LaAdmin}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushAccent}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Username -->
            <TextBlock
            Text="Tên đăng nhập"
            FontSize="13"
            Foreground="{DynamicResource BrushText}"
            FontWeight="Medium"
            Margin="30,0,30,8"/>

            <Grid Margin="30,0,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                Grid.Column="0"
                Text="👤"
                FontSize="18"
                VerticalAlignment="Center"
                Foreground="{DynamicResource BrushTextMuted}"/>

                <TextBox
                x:Name="UsernameTextBox"
                Grid.Column="1"
                Margin="10,0,0,0"
                Padding="10,12"
                FontSize="13"
                Foreground="{DynamicResource BrushText}"
                BorderThickness="1"
                BorderBrush="{DynamicResource BrushBorder}"
                Background="{DynamicResource BrushCardAlt}"
                Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Password -->
            <TextBlock 
            Text="Mật khẩu"
            FontSize="13"
            Foreground="{DynamicResource BrushText}"
            FontWeight="Medium"
            Margin="30,0,30,8"/>

            <Grid Margin="30,0,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                Grid.Column="0"
                Text="🔒"
                FontSize="18"
                VerticalAlignment="Center"
                Foreground="{DynamicResource BrushTextMuted}"/>

                <PasswordBox 
                x:Name="PasswordBox"
                Grid.Column="1"
                Margin="10,0,0,0"
                Padding="10,12"
                FontSize="13"
                BorderThickness="1"
                BorderBrush="{DynamicResource BrushBorder}"
                Background="{DynamicResource BrushCardAlt}"/>

                <TextBox
                x:Name="PasswordTextBox"
                Grid.Column="1"
                Margin="10,0,0,0"
                Padding="10,12"
                FontSize="13"
                BorderThickness="1"
                BorderBrush="{DynamicResource BrushBorder}"
                Background="{DynamicResource BrushCardAlt}"
                Visibility="Collapsed"/>

                <Button
                x:Name="TogglePasswordButton"
                Grid.Column="2"
                Content="Hiện"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{DynamicResource BrushPrimary}"
                FontSize="12"
                FontWeight="SemiBold"
                Padding="0"
                Click="TogglePasswordButton_Click"
                Cursor="Hand"/>
            </Grid>
            <!-- Quên mật khẩu -->
            <TextBlock TextAlignment="Right" Margin="30,0,30,16">
                <Hyperlink Foreground="{DynamicResource BrushPrimary}"
                           Command="{Binding LenhQuenMatKhau}"
                           CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Run Text="Quên mật khẩu?"/>
                </Hyperlink>
            </TextBlock>

            <!-- Nút Đăng nhập -->
            <Button
            x:Name="LoginButton"
            Content="🔐 ĐĂNG NHẬP"
            Style="{StaticResource PrimaryButton}"
            Margin="30,0,30,20"
            Padding="15,12"
            FontSize="14"
            Command="{Binding LenhDangNhap}"
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
            Cursor="Hand"/>

            <TextBlock
            TextAlignment="Center"
            Foreground="{DynamicResource BrushTextMuted}"
            FontSize="11"
            Margin="0,0,0,20">
            <Run Text="Khách hàng không cần đăng nhập — đóng cửa sổ này để tiếp tục mua sắm."/>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
