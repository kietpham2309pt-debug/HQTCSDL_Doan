<Window x:Class="Doan.View.UC_NhanVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan.ViewModel"
        mc:Ignorable="d"
        Title="UC_NhanVien" Height="750" Width="800">
    <Window.DataContext>
        <local:NhanVienViewModel/>
    </Window.DataContext>
    <Grid>
        <!-- Khung viền trắng bao quanh form -->
        <Border Background="White" Margin="25" Padding="30" CornerRadius="2" 
            BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Họ tên -->
                    <RowDefinition Height="Auto"/>
                    <!-- Ngày sinh & Giới tính -->
                    <RowDefinition Height="Auto"/>
                    <!-- Chức vụ & Lương -->
                    <RowDefinition Height="Auto"/>
                    <!-- Tìm kiếm & Nút -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- 1. Tiêu đề giống ảnh mẫu -->
                <Border Grid.Row="0" BorderBrush="#D1E3F8" BorderThickness="1" Background="#F4F8FD" Padding="15" Margin="0,0,0,25">
                    <TextBlock Text="QUẢN LÝ THÔNG TIN NHÂN VIÊN" FontSize="20" FontWeight="Bold" Foreground="#2A5C8A"/>
                </Border>

                <!-- 2. Họ tên nhân viên -->
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock Text="Họ tên nhân viên *" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <TextBox Height="40" Padding="10,0" VerticalContentAlignment="Center" FontSize="14"
                         BorderBrush="#D1D5DB" BorderThickness="1" 
                         Text="{Binding SelectedNV.HoTen}"/>
                </StackPanel>

                <!-- 3. Ngày sinh & Giới tính -->
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Ngày sinh *" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <DatePicker Height="40" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"
                                SelectedDate="{Binding SelectedNV.NgaySinh}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Giới tính *" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <ComboBox Height="40" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"
                              SelectedValuePath="Content" SelectedValue="{Binding SelectedNV.GioiTinh}">
                            <ComboBoxItem Content="Nam"/>
                            <ComboBoxItem Content="Nữ"/>
                            <ComboBoxItem Content="Khác"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- 4. Chức vụ & Mức lương -->
                <Grid Grid.Row="3" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Chức vụ *" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="10,0" VerticalContentAlignment="Center" FontSize="14"
                             BorderBrush="#D1D5DB" BorderThickness="1" 
                             Text="{Binding SelectedNV.ChucVu}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Mức lương (VNĐ) *" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="10,0" VerticalContentAlignment="Center" FontSize="14"
                             BorderBrush="#D1D5DB" BorderThickness="1" 
                             Text="{Binding SelectedNV.Luong}"/>
                    </StackPanel>
                </Grid>

                <!-- 5. Vùng Tìm kiếm và Các nút hành động -->
                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tìm kiếm -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,10,0"/>
                        <TextBox Width="200" Height="38" VerticalContentAlignment="Center" Padding="10,0"
                             BorderBrush="#D1D5DB" BorderThickness="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Nhóm nút bấm -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Xóa" Command="{Binding XoaCommand}" Width="80" Height="42" Margin="5,0" 
                            Background="#9CA3AF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Sửa" Command="{Binding SuaCommand}" Width="80" Height="42" Margin="5,0" 
                            Background="#F1C40F" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Thêm nhân viên" Command="{Binding ThemCommand}" Width="150" Height="42" Margin="5,0,0,0" 
                            Background="#2ECC71" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- 6. Bảng hiển thị DataGrid -->
                <DataGrid Grid.Row="5" ItemsSource="{Binding DanhSachNV}" 
                      SelectedItem="{Binding SelectedNV}" 
                      AutoGenerateColumns="True" CanUserAddRows="False" 
                      Height="220" Background="White" 
                      BorderBrush="#E5E7EB" BorderThickness="1"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"/>
            </Grid>
        </Border>
    </Grid>
</Window>
