<Window x:Class="Doan.DangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Doan"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Bán Xe Ô Tô" Height="600" Width="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Foreground="#333333">
    <Window.Resources>
        <DropShadowEffect 
            x:Key="ShadowEffect"
            BlurRadius="15"
            ShadowDepth="5"
            Opacity="0.3"/>
    </Window.Resources>
    <Grid Background="#34495e">
        <!-- Container chính -->
        <StackPanel 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center"
            Width="420"
            Background="White"
            Effect="{StaticResource ShadowEffect}">

            <!-- Header -->
            <TextBlock 
                Text="Đăng Nhập Hệ Thống"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#2c3e50"
                TextAlignment="Center"
                Margin="0,30,0,10"/>

            <TextBlock 
                Text="Hệ thống quản lý bán xe ô tô"
                FontSize="14"
                Foreground="#95a5a6"
                TextAlignment="Center"
                Margin="0,0,0,30"/>

            <!-- Username -->
            <TextBlock 
                Text="Tên đăng nhập"
                FontSize="13"
                Foreground="#2c3e50"
                FontWeight="Medium"
                Margin="30,0,30,8"/>

            <Grid Margin="30,0,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Grid.Column="0"
                    Text="👤"
                    FontSize="18"
                    VerticalAlignment="Center"
                    Foreground="#95a5a6"/>

                <TextBox 
                    x:Name="UsernameTextBox"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="10,12"
                    FontSize="13"
                    Foreground="#2c3e50"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#ecf0f1"
                    Background="Transparent"/>
            </Grid>

            <!-- Password -->
            <TextBlock 
                Text="Mật khẩu"
                FontSize="13"
                Foreground="#2c3e50"
                FontWeight="Medium"
                Margin="30,0,30,8"/>

            <Grid Margin="30,0,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Grid.Column="0"
                    Text="🔒"
                    FontSize="18"
                    VerticalAlignment="Center"
                    Foreground="#95a5a6"/>

                <PasswordBox 
                    x:Name="PasswordBox"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="10,12"
                    FontSize="13"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#ecf0f1"
                    Background="Transparent"/>

                <Button 
                    Grid.Column="2"
                    Content="👁"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#95a5a6"
                    FontSize="14"
                    Cursor="Hand"/>
            </Grid>

            <!-- Remember me & Forgot password -->
            <Grid Margin="30,0,30,20">
                <CheckBox 
                    x:Name="RememberMeCheckBox"
                    Content="Ghi nhớ tôi"
                    VerticalAlignment="Center"
                    Foreground="#7f8c8d"
                    FontSize="12"/>

                <TextBlock 
                    Text="Quên mật khẩu?"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="#3498db"
                    FontSize="12"
                    Cursor="Hand"/>
            </Grid>

            <!-- Nút Đăng nhập -->
            <Button 
                x:Name="LoginButton"
                Content="🔐 ĐĂNG NHẬP"
                Margin="30,0,30,20"
                Padding="15,12"
                FontSize="14"
                FontWeight="Bold"
                Foreground="White"
                Background="#3498db"
                BorderThickness="0"
                Cursor="Hand"
                Click="LoginButton_Click"/>

            <!-- Link tạo tài khoản -->
            <TextBlock 
                Text="Chưa có tài khoản? Liên hệ quản trị viên"
                TextAlignment="Center"
                Foreground="#7f8c8d"
                FontSize="11"
                Margin="0,0,0,20"/>
        </StackPanel>
    </Grid>
</Window>
