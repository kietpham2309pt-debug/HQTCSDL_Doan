<UserControl x:Class="Doan.Views.CarUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Doan"
             mc:Ignorable="d" 
             Height="Auto" Width="Auto"
             Background="#f5f5f5">
    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="350" MinWidth="350"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách xe -->
        <Grid Grid.Column="0" Margin="30,30,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Button 
                    Content="← Quay lại"
                    Click="BackButton_Click"
                    Background="#3498db"
                    Foreground="White"
                    Padding="12,8"
                    FontSize="12"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,15,0"/>

                <TextBlock 
                    x:Name="TitleTextBlock"
                    Text="Danh sách xe"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="#2c3e50"
                    VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Grid danh sách xe -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CarListControl" ItemsSource="{Binding XeList}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border 
                                Width="230" 
                                Height="300"
                                Margin="0,0,20,20"
                                Background="White"
                                CornerRadius="8"
                                MouseLeftButtonDown="CarItem_MouseLeftButtonDown"
                                Cursor="Hand"
                                Effect="{StaticResource ShadowEffect}">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel Orientation="Vertical">
                                    <!-- Ảnh xe -->
                                    <Image 
                                        Source="{Binding HinhAnh}"
                                        Height="180"
                                        Stretch="UniformToFill"
                                        VerticalAlignment="Top"/>

                                    <!-- Chi tiết xe -->
                                    <StackPanel Margin="15,15,15,15">
                                        <!-- Tên xe -->
                                        <TextBlock 
                                            Text="{Binding TenDong}"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="#2c3e50"
                                            Margin="0,0,0,10"/>

                                        <!-- Giá -->
                                        <TextBlock 
                                            Text="{Binding GiaBan, StringFormat='Giá từ {0:N0} VND'}"
                                            FontSize="12"
                                            Foreground="#e74c3c"
                                            FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Chi tiết xe bên phải -->
        <Border Grid.Column="1" Background="White" Margin="0,30,30,30" CornerRadius="8" Effect="{StaticResource ShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tiêu đề chi tiết -->
                <TextBlock 
                    Grid.Row="0"
                    Text="CHI TIẾT XE"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#2c3e50"
                    Margin="20,20,20,15"
                    
                    Padding="0,0,0,15"/>

                <!-- Nội dung chi tiết -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Margin="20,0,20,20">
                        <!-- Sẽ được load động khi click xe -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>

    
</UserControl>